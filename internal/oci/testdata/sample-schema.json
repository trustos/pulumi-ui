{
  "resources": {
    "oci:Core/instance:Instance": {
      "description": "Compute instance",
      "inputProperties": {
        "compartmentId": {
          "type": "string",
          "description": "OCID of the compartment"
        },
        "shape": {
          "type": "string"
        },
        "createVnicDetails": {
          "$ref": "#/types/oci:Core/InstanceCreateVnicDetails:InstanceCreateVnicDetails"
        },
        "sourceDetails": {
          "$ref": "#/types/oci:Core/InstanceSourceDetails:InstanceSourceDetails"
        },
        "shapeConfig": {
          "$ref": "#/types/oci:Core/InstanceShapeConfig:InstanceShapeConfig"
        },
        "metadata": {
          "type": "object"
        }
      },
      "properties": {
        "id": {
          "type": "string",
          "description": "OCID of the instance"
        },
        "publicIp": {
          "type": "string"
        }
      },
      "requiredInputs": ["compartmentId", "shape"]
    },
    "oci:Core/routeTable:RouteTable": {
      "description": "Route table for a VCN",
      "inputProperties": {
        "compartmentId": {
          "type": "string"
        },
        "vcnId": {
          "type": "string"
        },
        "routeRules": {
          "type": "array",
          "items": {
            "$ref": "#/types/oci:Core/RouteTableRouteRule:RouteTableRouteRule"
          }
        }
      },
      "requiredInputs": ["compartmentId", "vcnId"]
    },
    "oci:Core/networkSecurityGroupSecurityRule:NetworkSecurityGroupSecurityRule": {
      "description": "NSG security rule",
      "inputProperties": {
        "networkSecurityGroupId": {
          "type": "string"
        },
        "direction": {
          "type": "string"
        },
        "protocol": {
          "type": "string"
        },
        "tcpOptions": {
          "$ref": "#/types/oci:Core/NsgRuleTcpOptions:NsgRuleTcpOptions"
        }
      },
      "requiredInputs": ["networkSecurityGroupId", "direction", "protocol"]
    }
  },
  "types": {
    "oci:Core/InstanceCreateVnicDetails:InstanceCreateVnicDetails": {
      "type": "object",
      "properties": {
        "subnetId": {
          "type": "string",
          "description": "OCID of the subnet"
        },
        "assignPublicIp": {
          "type": "boolean",
          "description": "Whether to assign a public IP"
        },
        "nsgIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "displayName": {
          "type": "string"
        }
      },
      "required": ["subnetId"]
    },
    "oci:Core/InstanceSourceDetails:InstanceSourceDetails": {
      "type": "object",
      "properties": {
        "sourceType": {
          "type": "string",
          "description": "image or bootVolume"
        },
        "imageId": {
          "type": "string"
        },
        "bootVolumeSizeInGbs": {
          "type": "string"
        }
      },
      "required": ["sourceType"]
    },
    "oci:Core/InstanceShapeConfig:InstanceShapeConfig": {
      "type": "object",
      "properties": {
        "ocpus": {
          "type": "number"
        },
        "memoryInGbs": {
          "type": "number"
        }
      }
    },
    "oci:Core/RouteTableRouteRule:RouteTableRouteRule": {
      "type": "object",
      "properties": {
        "destination": {
          "type": "string",
          "description": "CIDR block for the route rule"
        },
        "networkEntityId": {
          "type": "string",
          "description": "OCID of the target gateway"
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["destination", "networkEntityId"]
    },
    "oci:Core/NsgRuleTcpOptions:NsgRuleTcpOptions": {
      "type": "object",
      "properties": {
        "destinationPortRange": {
          "$ref": "#/types/oci:Core/NsgRulePortRange:NsgRulePortRange"
        },
        "sourcePortRange": {
          "$ref": "#/types/oci:Core/NsgRulePortRange:NsgRulePortRange"
        }
      }
    },
    "oci:Core/NsgRulePortRange:NsgRulePortRange": {
      "type": "object",
      "properties": {
        "min": {
          "type": "integer",
          "description": "Lower bound"
        },
        "max": {
          "type": "integer",
          "description": "Upper bound"
        }
      },
      "required": ["min", "max"]
    }
  }
}
